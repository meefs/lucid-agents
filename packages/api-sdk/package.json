{
  "name": "@lucid-agents/api-sdk",
  "version": "4.0.0",
  "description": "TypeScript SDK for the Lucid Agents Runtime API (auto-generated from OpenAPI)",
  "repository": {
    "type": "git",
    "url": "https://github.com/daydreamsai/lucid-agents",
    "directory": "packages/api-sdk"
  },
  "type": "module",
  "lucidAgents": {
    "runtime": "portable",
    "bundlerExports": [
      "./react-query"
    ]
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/sdk/client/index.d.ts",
      "import": "./dist/sdk/client/index.js",
      "default": "./dist/sdk/client/index.js"
    },
    "./react-query": {
      "types": "./dist/sdk/@tanstack/react-query.gen.d.ts",
      "import": "./dist/sdk/@tanstack/react-query.gen.js",
      "default": "./dist/sdk/@tanstack/react-query.gen.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "generate": "bun run codegen.ts",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.88.2",
    "@tanstack/react-query": "^5.90.12",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    }
  }
}
