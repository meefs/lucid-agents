{
  "name": "@lucid-agents/payments",
  "version": "4.2.0",
  "description": "Payment logic for bidirectional agent-to-agent payments",
  "repository": {
    "type": "git",
    "url": "https://github.com/daydreamsai/lucid-agents",
    "directory": "packages/payments"
  },
  "type": "module",
  "lucidAgents": {
    "runtime": "portable",
    "nodeExports": [
      "./node",
      "./storage/sqlite",
      "./storage/postgres",
      "./providers/stripe"
    ]
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./storage/sqlite": {
      "types": "./dist/storage/sqlite.d.ts",
      "import": "./dist/storage/sqlite.js",
      "default": "./dist/storage/sqlite.js"
    },
    "./storage/postgres": {
      "types": "./dist/storage/postgres.d.ts",
      "import": "./dist/storage/postgres.js",
      "default": "./dist/storage/postgres.js"
    },
    "./providers/stripe": {
      "types": "./dist/providers/stripe.d.ts",
      "import": "./dist/providers/stripe.js",
      "default": "./dist/providers/stripe.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@lucid-agents/types": "workspace:*",
    "viem": "catalog:",
    "@x402/core": "catalog:",
    "@x402/fetch": "catalog:",
    "@x402/evm": "catalog:",
    "@x402/svm": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "pg": "^8.13.1",
    "stripe": "^20.3.1"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "stripe": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "catalog:",
    "typescript": "catalog:",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "stripe": "catalog:"
  }
}
