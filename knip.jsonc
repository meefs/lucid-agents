{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "include": [
    "files",
    "dependencies",
    "devDependencies",
    "unlisted",
    "unresolved",
    "exports",
    "types",
    "duplicates",
  ],
  "ignore": [
    ".context/**",
    "**/.context/**",
    "**/dist/**",
    "**/.output/**",
    "**/coverage/**",
    "**/reports/**",
    "**/*.tsbuildinfo",
  ],
  "ignoreIssues": {
    "packages/api-sdk/src/sdk/**": ["exports", "types"],
    "packages/cli/adapters/tanstack/**/src/routeTree.gen.ts": [
      "files",
      "exports",
      "types",
      "unresolved",
    ],
    "packages/mpp/src/middleware.ts": ["duplicates"],
    "lucid-docs/src/routeTree.gen.ts": ["exports", "types"],
  },
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.ts", "*.config.{js,ts}"],
      "project": ["scripts/**/*.ts", "*.config.{js,ts}"],
    },
    "packages/*": {
      "entry": [
        "src/index.ts",
        "src/node.ts",
        "src/**/*.test.ts",
        "tests/**/*.test.ts",
        "examples/**/*.ts",
      ],
      "project": [
        "src/**/*.ts",
        "tests/**/*.ts",
        "examples/**/*.ts",
        "*.config.ts",
      ],
    },
    "packages/cli": {
      "entry": ["src/index.ts", "src/**/*.test.ts", "tests/**/*.test.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts", "*.config.ts"],
      "ignoreDependencies": [
        "@lucid-agents/http",
        "@solana/kit",
        "@solana/web3.js",
        "@x402/core",
      ],
    },
    "packages/cli/adapters/express": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": [
        "@lucid-agents/core",
        "@lucid-agents/express",
        "zod",
      ],
      "ignoreUnresolved": ["./lib/agent"],
    },
    "packages/cli/adapters/hono": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@lucid-agents/core", "@lucid-agents/hono", "zod"],
      "ignoreUnresolved": ["./lib/agent"],
    },
    "packages/cli/adapters/next": {
      "entry": ["**/*.{ts,tsx}"],
      "project": [
        "app/**/*.{ts,tsx}",
        "components/**/*.{ts,tsx}",
        "lib/**/*.ts",
      ],
      "ignoreDependencies": [
        "@lucid-agents/core",
        "@lucid-agents/types",
        "@solana/kit",
        "@solana/web3.js",
        "@x402/evm",
        "@x402/fetch",
        "@x402/svm",
        "react-dom",
        "lucide-react",
        "tailwindcss",
        "@wagmi/connectors",
        "@wagmi/core",
        "zod",
        "@types/react-dom",
      ],
      "ignoreUnresolved": [
        "@/lib/agent",
        "@/components/service-storefront",
        "@/service-ui.config",
      ],
    },
    "packages/cli/adapters/tanstack/headless": {
      "entry": ["src/**/*.{ts,tsx}", "*.config.ts"],
      "project": ["src/**/*.{ts,tsx}", "*.config.{ts,mjs}"],
      "ignoreDependencies": [
        "@lucid-agents/core",
        "@lucid-agents/tanstack",
        "@reown/appkit",
        "@reown/appkit-adapter-solana",
        "@reown/appkit-adapter-wagmi",
        "@tanstack/react-devtools",
        "@tanstack/react-router-devtools",
        "@tanstack/router-plugin",
        "clsx",
        "lucide-react",
        "tailwind-merge",
        "viem",
        "wagmi",
        "@x402/fetch",
        "@x402/evm",
        "@wagmi/connectors",
        "@wagmi/core",
        "zod",
        "bun-types",
      ],
      "ignoreUnresolved": ["@/lib/agent"],
      "vite": false,
    },
    "packages/cli/adapters/tanstack/ui": {
      "entry": ["src/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}", "*.config.{ts,mjs}"],
      "ignoreDependencies": [
        "@lucid-agents/core",
        "@lucid-agents/tanstack",
        "@lucid-agents/types",
        "@solana/kit",
        "@solana/web3.js",
        "@tanstack/nitro-v2-vite-plugin",
        "@tanstack/react-devtools",
        "@tanstack/react-router-devtools",
        "@tanstack/react-router-ssr-query",
        "@tanstack/react-start",
        "@tanstack/router-plugin",
        "clsx",
        "lucide-react",
        "tailwind-merge",
        "tailwindcss-animate",
        "tailwindcss",
        "@x402/fetch",
        "@x402/evm",
        "@x402/svm",
        "@wagmi/connectors",
        "@wagmi/core",
        "zod",
        "@tailwindcss/postcss",
        "@tailwindcss/vite",
        "@vitejs/plugin-react",
        "postcss",
        "bun-types",
        "vite-tsconfig-paths",
      ],
      "ignoreUnresolved": [
        "@/lib/agent",
        "@/lib/api",
        "@/lib/network",
        "@/lib/utils",
        "@/components/schema-form",
        "@/components/service-storefront",
        "@/components/wallet-summary",
        "../../service-ui.config",
      ],
      "vite": false,
    },
    "lucid-docs": {
      "entry": [
        "src/start.ts",
        "src/routes/**/*.{ts,tsx}",
        "examples/buyer.ts",
        "examples/**/*.test.ts",
        "*.config.{ts,tsx}",
      ],
      "project": ["src/**/*.{ts,tsx}", "examples/**/*.ts", "*.config.{ts,tsx}"],
      "ignoreUnresolved": ["./routeTree.gen"],
    },
  },
}
