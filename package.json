{
  "name": "@lucid-agents/root",
  "packageManager": "bun@1.3.10",
  "workspaces": {
    "packages": [
      "packages/*",
      "lucid-docs"
    ],
    "catalog": {
      "zod": "^4.1.12",
      "typescript": "^5.9.2",
      "hono": "4.10.1",
      "express": "^4.19.2",
      "mppx": "^0.4.11",
      "viem": "^2.44.4",
      "@x402/core": "^2.2.0",
      "@x402/fetch": "^2.2.0",
      "@x402/evm": "^2.2.0",
      "@x402/svm": "2.2.0",
      "@x402/hono": "^2.2.0",
      "@x402/express": "^2.2.0",
      "@x402/next": "^2.2.0",
      "stripe": "^20.3.1",
      "tsup": "^8.5.0"
    }
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "build": "bun run scripts/build-packages.ts",
    "build:clean": "bun run scripts/build-packages.ts --clean",
    "build:packages": "bun run scripts/build-packages.ts",
    "changeset": "bunx changeset",
    "release:version": "bunx changeset version",
    "release:publish": "bun run release:publish:verified",
    "release:publish:verified": "bun run scripts/release-policy.ts verify-publish && bun run scripts/build-packages.ts && git diff --exit-code && bun run scripts/release-policy.ts verify-publish && bun run scripts/changeset-publish.ts",
    "release": "bun run release:publish:verified",
    "lint": "bun run --filter='./packages/*' lint",
    "lint:fix": "bun run --filter='./packages/*' lint:fix",
    "deadcode": "knip --no-config-hints",
    "format": "bun run --filter='./packages/*' format",
    "format:check": "bun run --filter='./packages/*' format:check",
    "type-check": "bun run --filter='./packages/*' type-check",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov && bun run scripts/check-coverage.ts",
    "test:ci": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov --reporter=junit --reporter-outfile=reports/junit.xml && bun run scripts/check-coverage.ts && bun run scripts/check-test-results.ts reports/junit.xml",
    "test:e2e": "bun test packages/examples/src/__tests__ packages/examples/src/kitchen-sink/__tests__",
    "test:browser": "bash scripts/test-browser-smoke.sh",
    "test:generated": "bun run scripts/test-generated-project.ts all",
    "test:docs": "bun test scripts/docs-content.test.ts scripts/docs-drift.test.ts scripts/docs-maintenance.test.ts scripts/docs-snippets.test.ts scripts/lucid-skill.test.ts lucid-docs/src/lib/docs-telemetry.test.ts lucid-docs/examples/paid-service.test.ts && bun run scripts/check-docs-content.ts && bun run docs:drift && bun run skill:validate",
    "test:docs-stable": "bun run scripts/test-docs-stable-quickstart.ts",
    "docs:drift": "bun run scripts/check-docs-drift.ts",
    "docs:links": "bun run scripts/check-docs-external-links.ts",
    "docs:freshness": "bun run scripts/report-docs-freshness.ts",
    "test:portability": "bun run scripts/check-runtime-portability.ts",
    "skill:assets": "bun run scripts/build-lucid-skill-assets.ts",
    "skill:eval:prepare": "bun run scripts/prepare-lucid-skill-evals.ts",
    "skill:eval:validate": "bun run scripts/validate-lucid-skill-eval-results.ts",
    "skill:release": "bun run scripts/release-lucid-skill.ts",
    "skill:test": "bun test scripts/lucid-skill.test.ts",
    "skill:validate": "bun run scripts/validate-lucid-skill.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@types/bun": "^1.2.21",
    "@types/node": "^24.3.1",
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@lucid-agents/types": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.1.7",
    "knip": "6.27.0",
    "prettier": "^3.0.0"
  }
}
