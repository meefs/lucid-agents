# MPP Paid Service Agent - Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp env.example .env

# ─── Tempo Payment Method ───────────────────────────────────────
# Token contract address on Tempo Network (e.g., pathUSD)
MPP_TEMPO_CURRENCY=0x20c0000000000000000000000000000000000000

# Wallet address to receive payments
MPP_TEMPO_RECIPIENT=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266

# Optional: Chain ID for Tempo Network
# MPP_TEMPO_CHAIN_ID=

# ─── General MPP Config ─────────────────────────────────────────
# Default currency (default: usd)
MPP_CURRENCY=usd

# Default payment intent: 'charge' (one-time) or 'session' (streaming)
MPP_DEFAULT_INTENT=charge

# Challenge expiry in seconds (default: 300)
# MPP_CHALLENGE_EXPIRY=300

# ─── Server ─────────────────────────────────────────────────────
PORT=3000
