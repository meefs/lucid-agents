{
  "name": "@lucid-agents/examples",
  "version": "0.4.0",
  "description": "Example implementations for lucid-agents framework",
  "type": "module",
  "lucidAgents": {
    "runtime": "examples"
  },
  "private": true,
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "type-check": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@lucid-agents/a2a": "workspace:*",
    "@lucid-agents/analytics": "workspace:*",
    "@lucid-agents/ap2": "workspace:*",
    "@lucid-agents/catalog": "workspace:*",
    "@lucid-agents/core": "workspace:*",
    "@lucid-agents/express": "workspace:*",
    "@lucid-agents/hono": "workspace:*",
    "@lucid-agents/http": "workspace:*",
    "@lucid-agents/identity": "workspace:*",
    "@lucid-agents/mpp": "workspace:*",
    "@lucid-agents/payments": "workspace:*",
    "@lucid-agents/scheduler": "workspace:*",
    "@lucid-agents/tanstack": "workspace:*",
    "@lucid-agents/types": "workspace:*",
    "@lucid-agents/wallet": "workspace:*",
    "@lucid-dreams/agent-auth": "^0.2.24",
    "thirdweb": "^5.113.0",
    "mppx": "^0.1.0",
    "viem": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "tsup": "catalog:",
    "typescript": "catalog:",
    "@lucid-agents/eslint-config": "workspace:*"
  }
}
